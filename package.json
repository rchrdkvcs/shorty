    "@japa/plugin-adonisjs": "^5.1.0",
    "@japa/runner": "^5.0.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/luxon": "^3.6.2",
    "@types/node": "^25.3.3",
    "@types/qrcode": "^1.5.5",
    "@vitejs/plugin-vue": "^6.0.4",
    "eslint": "^10.0.2",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "typescript": "~5.9.0",
    "vite": "^7.0.0",
    "youch": "^4.1.0"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.0.0",
    "@adonisjs/core": "^7.0.1",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/inertia": "^4.1.0",
    "@adonisjs/lucid": "^22.0.0",
    "@adonisjs/session": "^8.0.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.0",
    "@adonisjs/vite": "^5.1.0",
    "@iconify-json/lucide": "^1.2.95",
    "@iconify-json/simple-icons": "^1.2.72",
    "@inertiajs/vue3": "^2.3.17",
    "@nuxt/ui": "^4.5.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tuyau/core": "^1.0.0",
    "@vinejs/vine": "^4.3.0",
    "@vueuse/core": "^14.2.1",
    "edge.js": "^6.5.0",
    "luxon": "^3.6.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "tailwindcss": "^4.2.1",
    "ulid": "^3.0.1",
    "vue": "^3.5.29"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
